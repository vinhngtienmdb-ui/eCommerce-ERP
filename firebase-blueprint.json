{
  "entities": {
    "Settings": {
      "title": "System Settings",
      "description": "Global system configuration settings",
      "type": "object",
      "properties": {
        "general": { "type": "object" },
        "appearance": { "type": "object" },
        "notifications": { "type": "object" },
        "fees": { "type": "object" },
        "categories": { "type": "array" },
        "integrations": { "type": "object" },
        "shipping": { "type": "object" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Records of user actions for auditing",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "module": { "type": "string" },
        "details": { "type": "string" },
        "ipAddress": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "module", "timestamp"]
    },
    "UserRole": {
      "title": "User Role",
      "description": "Role and permissions for a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string" },
        "permissions": { "type": "object" }
      },
      "required": ["uid", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information",
      "type": "object",
      "properties": {
        "productName": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "baseName": { "type": "string" },
        "specifications": { "type": "string" },
        "category": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "coverImage": { "type": "string" },
        "video": { "type": "string" },
        "variants": { "type": "array" },
        "combinations": { "type": "array" },
        "shipping": { "type": "object" },
        "other": { "type": "object" },
        "status": { "type": "string", "enum": ["published", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["productName", "category", "userId"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Document": {
      "title": "Document",
      "description": "Administrative document",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "number": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "object" },
        "status": { "type": "string", "enum": ["draft", "pending_signature", "signed", "issued", "archived"] },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "direction": { "type": "string", "enum": ["incoming", "outgoing"] },
        "sender": { "type": "string" },
        "receiver": { "type": "string" },
        "fileUrl": { "type": "string" },
        "wordUrl": { "type": "string" },
        "signatureSteps": { "type": "array" }
      }
    },
    "DocumentTemplate": {
      "title": "Document Template",
      "description": "Template for administrative documents",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "fields": { "type": "array" }
      }
    },
    "DocumentSettings": {
      "title": "Document Settings",
      "description": "Configuration for document management",
      "type": "object",
      "properties": {
        "autoNumbering": { "type": "boolean" },
        "prefix": { "type": "string" },
        "currentNumber": { "type": "integer" },
        "suffix": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "Settings",
      "description": "Global system settings"
    },
    "/settings/documents": {
      "schema": "DocumentSettings",
      "description": "Document management settings"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit logs"
    },
    "/user_roles/{uid}": {
      "schema": "UserRole",
      "description": "User roles and permissions"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product listings"
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Administrative documents"
    },
    "/document_templates/{templateId}": {
      "schema": "DocumentTemplate",
      "description": "Document templates"
    }
  }
}
