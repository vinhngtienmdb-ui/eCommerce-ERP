{
  "entities": {
    "LegalPolicy": {
      "title": "Legal Policy",
      "description": "Content for legal and compliance policies",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["privacy", "operating", "shipping", "refund"] },
        "content": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["type", "content"]
    },
    "Settings": {
      "title": "System Settings",
      "description": "Global system configuration settings",
      "type": "object",
      "properties": {
        "general": { "type": "object" },
        "appearance": { "type": "object" },
        "notifications": { "type": "object" },
        "fees": { "type": "object" },
        "categories": { "type": "array" },
        "integrations": { "type": "object" },
        "shipping": { "type": "object" },
        "paymentGateways": { "type": "object" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Records of user actions for auditing",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "module": { "type": "string" },
        "details": { "type": "string" },
        "ipAddress": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "module", "timestamp"]
    },
    "UserRole": {
      "title": "User Role",
      "description": "Role and permissions for a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string" },
        "permissions": { "type": "object" }
      },
      "required": ["uid", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information",
      "type": "object",
      "properties": {
        "productName": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "baseName": { "type": "string" },
        "specifications": { "type": "string" },
        "category": { "type": "array", "items": { "type": "string" } },
        "categoryLevel1": { "type": "string" },
        "categoryLevel2": { "type": "string" },
        "categoryLevel3": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "coverImage": { "type": "string" },
        "video": { "type": "string" },
        "variants": { "type": "array" },
        "combinations": { "type": "array" },
        "shipping": { "type": "object" },
        "other": { "type": "object" },
        "status": { "type": "string", "enum": ["published", "hidden"] },
        "stock": { "type": "number", "description": "Current inventory level" },
        "lowStockThreshold": { "type": "number", "description": "Threshold for low stock alert" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["productName", "category", "userId"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Document": {
      "title": "Document",
      "description": "Administrative document",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "number": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "object" },
        "status": { "type": "string", "enum": ["draft", "pending_signature", "signed", "issued", "archived"] },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "direction": { "type": "string", "enum": ["incoming", "outgoing"] },
        "sender": { "type": "string" },
        "receiver": { "type": "string" },
        "fileUrl": { "type": "string" },
        "wordUrl": { "type": "string" },
        "signatureSteps": { "type": "array" }
      }
    },
    "DocumentTemplate": {
      "title": "Document Template",
      "description": "Template for administrative documents",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "fields": { "type": "array" }
      }
    },
    "DocumentSettings": {
      "title": "Document Settings",
      "description": "Configuration for document management",
      "type": "object",
      "properties": {
        "autoNumbering": { "type": "boolean" },
        "prefix": { "type": "string" },
        "currentNumber": { "type": "integer" },
        "suffix": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer profile and loyalty information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "totalOrders": { "type": "integer" },
        "totalSpent": { "type": "number" },
        "walletBalance": { "type": "number" },
        "pointsBalance": { "type": "number" },
        "lastOrder": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "vip", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Order": {
      "title": "Order",
      "description": "POS Order record",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "pointsUsed": { "type": "number" },
        "total": { "type": "number" },
        "platformFee": { "type": "number" },
        "pointsEarned": { "type": "number" },
        "storeCredit": { "type": "number" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "status": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["cash", "card", "wallet", "dealtot", "split"] },
        "payments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "method": { "type": "string", "enum": ["cash", "card", "wallet", "dealtot"] },
              "amount": { "type": "number" }
            }
          }
        },
        "shiftId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" },
        "storeId": { "type": "string" }
      },
      "required": ["items", "total", "createdAt"]
    },
    "Staff": {
      "title": "Staff",
      "description": "POS Staff member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "Shipment": {
      "title": "Shipment",
      "description": "Logistics shipment tracking",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customer": { "type": "string" },
        "carrier": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "status": { "type": "string" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "customer"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "Warehouse location and capacity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "capacity": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["name", "location"]
    },
    "Store": {
      "title": "Store Profile",
      "description": "POS Store profile and business configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "storeCode": { "type": "string", "description": "Unique store identifier" },
        "ownerType": { "type": "string", "enum": ["Enterprise", "Household", "Individual"] },
        "ownerName": { "type": "string" },
        "ownerContact": { "type": "string" },
        "taxId": { "type": "string" },
        "managerContact": { "type": "string" },
        "customUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" },
        "settings": { "type": "object" }
      },
      "required": ["name", "storeCode"]
    },
    "Branch": {
      "title": "Store Branch",
      "description": "Physical branch of a store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "branchCode": { "type": "string", "description": "StoreCode + Sequence" },
        "address": {
          "type": "object",
          "properties": {
            "province": { "type": "string" },
            "district": { "type": "string" },
            "detail": { "type": "string" }
          }
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "managerName": { "type": "string" },
        "managerContact": { "type": "string" },
        "customUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "branchCode"]
    },
    "StoreRegistration": {
      "title": "Store Registration",
      "description": "Workflow for store onboarding",
      "type": "object",
      "properties": {
        "partnerName": { "type": "string" },
        "partnerContact": { "type": "string" },
        "businessType": { "type": "string" },
        "documents": { "type": "array", "items": { "type": "string" }, "description": "Base64 or URLs of documents" },
        "storefrontImage": { "type": "string", "description": "Base64 of storefront image" },
        "status": { "type": "string", "enum": ["pending_registration", "pending_verification", "pending_contract", "pending_approval", "approved", "rejected"] },
        "fieldSaleVerification": {
          "type": "object",
          "properties": {
            "verifiedBy": { "type": "string" },
            "verifiedAt": { "type": "string", "format": "date-time" },
            "verificationImages": { "type": "array", "items": { "type": "string" } },
            "location": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            },
            "notes": { "type": "string" }
          }
        },
        "contractSigned": { "type": "boolean" },
        "contractUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["partnerName", "partnerContact", "status"]
    },
    "Shift": {
      "title": "Work Shift",
      "description": "Staff work shift record",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "startCash": { "type": "number" },
        "endCash": { "type": "number" },
        "totalSales": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "storeId": { "type": "string" },
        "branchId": { "type": "string" }
      },
      "required": ["staffId", "startTime", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "stock", "system"] },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "body", "type", "createdAt"]
    }
  },
  "firestore": {
    "/legal_policies/{policyId}": {
      "schema": "LegalPolicy",
      "description": "Legal and compliance policies"
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global system settings"
    },
    "/settings/documents": {
      "schema": "DocumentSettings",
      "description": "Document management settings"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit logs"
    },
    "/user_roles/{uid}": {
      "schema": "UserRole",
      "description": "User roles and permissions"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product listings"
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Administrative documents"
    },
    "/document_templates/{templateId}": {
      "schema": "DocumentTemplate",
      "description": "Document templates"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "POS Orders"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "POS Staff members"
    },
    "/shipments/{shipmentId}": {
      "schema": "Shipment",
      "description": "Logistics shipment tracking"
    },
    "/warehouses/{warehouseId}": {
      "schema": "Warehouse",
      "description": "Warehouse management"
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "POS Store profiles"
    },
    "/stores/{storeId}/branches/{branchId}": {
      "schema": "Branch",
      "description": "Store branches"
    },
    "/stores/{storeId}/products/{productId}": {
      "schema": "Product",
      "description": "Store-specific products"
    },
    "/stores/{storeId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Store-specific orders"
    },
    "/stores/{storeId}/staff/{staffId}": {
      "schema": "Staff",
      "description": "Store-specific staff"
    },
    "/stores/{storeId}/branches/{branchId}/products/{productId}": {
      "schema": "Product",
      "description": "Branch-specific products"
    },
    "/stores/{storeId}/branches/{branchId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Branch-specific orders"
    },
    "/stores/{storeId}/branches/{branchId}/staff/{staffId}": {
      "schema": "Staff",
      "description": "Branch-specific staff"
    },
    "/store_registrations/{registrationId}": {
      "schema": "StoreRegistration",
      "description": "Store onboarding registrations"
    },
    "/stores/{storeId}/shifts/{shiftId}": {
      "schema": "Shift",
      "description": "Store-specific work shifts"
    },
    "/stores/{storeId}/branches/{branchId}/shifts/{shiftId}": {
      "schema": "Shift",
      "description": "Branch-specific work shifts"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications"
    }
  }
}
